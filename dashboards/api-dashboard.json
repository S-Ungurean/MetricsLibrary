{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    }
  ],
  "description": "HealthAI API request counts, error rates, availability and latency",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Total Successful Requests",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "increase(api_request_count_total{status=\"success\", deployment_environment=~\"$environment\", service_name=~\"$service\"}[5m])",
          "legendFormat": "{{operation}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Failed Requests — 4xx vs 5xx",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "increase(api_request_count_total{status=\"client_error\", deployment_environment=~\"$environment\", service_name=~\"$service\"}[5m])",
          "legendFormat": "4xx — {{operation}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "increase(api_request_count_total{status=\"server_error\", deployment_environment=~\"$environment\", service_name=~\"$service\"}[5m])",
          "legendFormat": "5xx — {{operation}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 3,
      "title": "Availability",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "fixed", "fixedColor": "green" },
          "custom": {
            "thresholdsStyle": { "mode": "dashed" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "transparent", "value": null },
              { "color": "red", "value": 95 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "100 * sum(api_request_count_total{status=\"success\", deployment_environment=~\"$environment\", service_name=~\"$service\"}) / (sum(api_request_count_total{status=\"success\", deployment_environment=~\"$environment\", service_name=~\"$service\"}) + (sum(api_request_count_total{status=\"server_error\", deployment_environment=~\"$environment\", service_name=~\"$service\"}) or vector(0)))",
          "legendFormat": "availability",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "p95 Latency by Operation",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum by(le, operation) (rate(api_request_duration_milliseconds_bucket{deployment_environment=~\"$environment\", service_name=~\"$service\"}[5m])))",
          "legendFormat": "{{operation}} p95",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "p99 Latency by Operation",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, sum by(le, operation) (rate(api_request_duration_milliseconds_bucket{deployment_environment=~\"$environment\", service_name=~\"$service\"}[5m])))",
          "legendFormat": "{{operation}} p99",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["healthai", "api"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource",
        "label": "Datasource"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(api_request_count_total, deployment_environment)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "environment",
        "label": "Environment",
        "query": {
          "query": "label_values(api_request_count_total, deployment_environment)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(api_request_count_total, service_name)",
        "hide": 0,
        "includeAll": true,
        "multi": false,
        "name": "service",
        "label": "Service",
        "query": {
          "query": "label_values(api_request_count_total, service_name)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "HealthAI — API Metrics",
  "uid": "healthai-api-metrics",
  "version": 1
}
